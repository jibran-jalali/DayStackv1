POSTGRES_URL=
# Optional but recommended for migrations:
# POSTGRES_URL_NON_POOLING=

AUTH_SECRET=
# Optional for DayStack Assistant:
# Preferred provider for stronger general reasoning:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# Optional web-backed answer model override:
# OPENAI_WEB_MODEL=gpt-5
#
# Groq remains supported as a fallback or alternative:
# GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b
# Optional Groq web-backed answer model:
# GROQ_WEB_MODEL=groq/compound-mini
# Local development callback origin for NextAuth:
# NEXTAUTH_URL=http://localhost:3000

# Optional for Gmail SMTP reminder emails:
# GMAIL_SMTP_USER=
# GMAIL_SMTP_APP_PASSWORD=
# EMAIL_FROM_NAME=DayStack

# Optional for reminder dispatch from Vercel Cron:
# CRON_SECRET=

# Required for the internal /admin dashboard:
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional but recommended to separate admin session signing:
# ADMIN_SESSION_SECRET=
